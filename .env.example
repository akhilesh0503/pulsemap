POSTGRES_USER=pulsemap
POSTGRES_PASSWORD=pulsemap
POSTGRES_DB=pulsemap
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql://pulsemap:pulsemap@postgres:5432/pulsemap
SYNC_DATABASE_URL=postgresql://pulsemap:pulsemap@postgres:5432/pulsemap

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379

KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_TOPIC_RAW_TRIPS=raw_trips
KAFKA_TOPIC_ZONE_UPDATES=zone_updates
KAFKA_CONSUMER_GROUP_STREAM=stream-processor-group

MLFLOW_TRACKING_URI=http://mlflow_service:5000
MLFLOW_EXPERIMENT_NAME=pulsemap-demand-forecast

DATA_DIR=/app/data
MODELS_DIR=/app/models
H3_RESOLUTION=8
MIN_ZONE_TRIPS=10
SURGE_CAP=3.5
STREAM_WINDOW_MINUTES=2
FORECAST_HORIZON_MINUTES=15
FORECAST_INTERVAL_SECONDS=120
PSI_ALERT_THRESHOLD=0.2
SIMULATOR_SPEED_MULTIPLIER=60
LOG_LEVEL=INFO
